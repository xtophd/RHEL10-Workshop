##
##    !! WARNING !!  Ansible only interprets 'True' and 'False'
##                   as booleans when reading ini files.  Other
##                   values such as 'true' or 'false' would be 
##                   interpreted as strings and would break various
##                   logic tests.  
##
##                   When reading YML files, booleans can take on
##                   many forms and be interpreted correctly.
##
##                   For consistency, only use unquoted booleans: True & False

all: 

  vars:

    ## ----------------------------------------
    ##    Establish defaults for virthost type

{%if lookup('env',"VIRTHOST_TYPE") == "libvirt" %}
    h_hwPROF:        "kvm_vda_q35"
    h_plPROF:        "custom_platform"
{%elif lookup('env',"VIRTHOST_TYPE") == "ovirt" %}
    h_hwPROF:        "ovirt_sda"
    h_plPROF:        "custom_platform"
{%endif %}

    ## ----------------------------------------
    ##    Workshop Variables

    workshop_vars:

      projectname:          "{{ lookup('env','PROJECT_NAME')    }}"

      ldap_client:          {{ lookup('env','LDAP')            }}
      ldap_uri:             "{{ lookup('env','LDAP_URI')        }}"
      ldap_base_dn:         "{{ lookup('env','LDAP_BASE_DN')         }}"
      ldap_bind_dn:         "{{ lookup('env','LDAP_BIND_DN')    }}"
      ldap_bind_pw:         "{{ lookup('env','LDAP_BIND_PW')    }}"
      ldap_sudo_grp:        "{{ lookup('env','LDAP_SUDO_GRP')   }}"

      network_id:           "{{ lookup('env','NETWORK_ID')          }}"
      network_gateway:      "{{ lookup('env','NETWORK_GATEWAY')     }}"
      network_prefix:       "{{ lookup('env','NETWORK_PREFIX')      }}"
      network_broadcast:    "{{ lookup('env','NETWORK_BROADCAST')   }}"
      network_netmask:      "{{ lookup('env','NETWORK_NETMASK')     }}"
      network_basedomain:   "{{ lookup('env','NETWORK_BASEDOMAIN')  }}"
      network_subdomain:    "{{ lookup('env','NETWORK_SUBDOMAIN')   }}"
      network_nameserver:   "{{ lookup('env','NETWORK_DNS_SERVER')  }}"
      network_timeserver:   "{{ lookup('env','NETWORK_TIME_SERVER') }}"

      ##
      ##    NOTE:
      ##        User & Admin UID/PW are stored 
      ##        in the credentials file. Never here!!!
      ##

      set_admin_password:   True
      set_student_password: True

      bastion:
        firewalld:          {{ lookup('env','BASTION_FW')      }}
        dns:                {{ lookup('env','BASTION_DNS')     }}
        dhcp:               {{ lookup('env','BASTION_DHCP')    }}
        dhcp_pxe:           {{ lookup('env','BASTION_DHCP')    }}
        dhcp_uefi_http:     {{ lookup('env','BASTION_DHCP')    }}
        haproxy:            {{ lookup('env','BASTION_HAPROXY') }}
        nfs:                {{ lookup('env','BASTION_NFS')     }}
        ntp:                {{ lookup('env','BASTION_NTP')     }}
        squid:              {{ lookup('env','BASTION_SQUID')   }}

      enable_unit:
        appstream:          True
        boom:               True
        buildah:            True
        ebpf:               True
        firewalld:          True
        kpatch:             True
        nftables:           True
        podman:             True
        stratis:            True
        systemd:            True
        tlog:               True
        imagebuilder:       True
        virtualization:     True
        vdo:                True
        wayland:            True
        leapp:              True
        webconsole:         True
        showroom:           False

    workshop_extras:

#      network_fqdn:         {{ lookup('env',"NETWORK_BASEDOMAIN") }}

      squid_http_url:       "http://bastion.{{ t_network_basedomain }}:3128"
      squid_https_url:      ""




    ## ----------------------------------------
    ##    Xtoph Deploy Variables

    xtoph_vars:

      deployhost_ip:       "{{ t_ansible_ip }}"
      projectname:         "{{ t_project_name }}"
      tmp_dir:             "/home/tmp/{{ t_project_name }}/{% raw %}{{ inventory_hostname_short }}{% endraw %}"



## ----------------------------------------
## HOSTGROUPS & VARS
## ----------------------------------------

myLibvirtHosts:

  hosts:
{% if t_virthost_type == "libvirt" and t_virthost_fqdn|length %}
    {{ t_virthost_fqdn }}:
      h_netIP:  "{{ t_virthost_ip }}"
{% if t_virthost_fqdn == "localhost.localdomain" %}
      ansible_connection: local
{% endif %}

{% if t_virthost_hw|length  %}
      h_hwPROF:  "{{ t_virthost_hw }}"
      h_plPROF:  "custom_baremetal"
      h_plSETUP: "custom_platform"
      h_rsPROF:  "med"
      h_pwrOFF:  false
      h_ksPROF:  "rhel92-bootiso"
{% else %}
      h_hwPROF:  "pc_sda"
      h_plSETUP: "custom_platform"
      h_rsPROF:  "med"
{% endif %}

{% if t_virthost_bmc|length  %}
      bmc_fqdn:        "{{ t_virthost_bmc }}"
{% endif %}

{% endif %}



## -----------------



myDeployhost:
  hosts:
    deployer:
      h_netIP:       {% raw %}"{{ xtoph_vars.deployhost_ip }}"{% endraw %}

  vars:
    ansible_connection: local



{% for hgroup in [ "myBastion", "myNodes", "myLeapp" ] %}

## -----------------
{{ hgroup }} :
  hosts:
{% for index in range(1,9) %}
{%     if  lookup('env',"HGROUP_NODE" ~ index) == hgroup %}

    {{ lookup('env',"NAME_NODE" ~ index) }}.{{ lookup('env',"NETWORK_SUBDOMAIN") }} : 
      h_netIP:         "{{ lookup('env',"ADDR_NODE" ~ index) }}"
{%       if lookup('env',"MAC_NODE" ~ index)|length %}
      h_netMAC:        "{{ lookup('env',"MAC_NODE" ~ index) }}"
{%       endif %}
{%       if lookup('env',"NETMODE_NODE" ~ index)|length %}
      h_netMODE:       "{{ lookup('env',"NICMODE_NODE" ~ index) }}"
{%       endif %}
{%       if lookup('env',"NETDEV_NODE" ~ index)|length %}
      h_netDEV:        "{{ lookup('env',"NETDEV_NODE" ~ index) }}"
{%       endif %}
{%       if lookup('env',"BLKDEV_NODE" ~ index)|length %}
      h_blkDEV:        "{{ lookup('env',"BLKDEV_NODE" ~ index) }}"
{%       endif %}
{%       if lookup('env',"HW_NODE" ~ index)|length %}
      h_hwPROF:        "{{ lookup('env',"HW_NODE" ~ index) }}"
      h_plPROF:        "custom_baremetal"
{%       endif %}
      h_ksPROF:        "{{ lookup('env',"KS_NODE" ~ index) }}"
      h_rsPROF:        "{{ lookup('env',"RES_NODE" ~ index) }}"
      h_kernelOPTS:    "{{ lookup('env',"KOPTS_NODE" ~ index) }}"
{%     endif %}
{% endfor %}
{% endfor %}
